    {
      "parameters": {
        "jsCode": "\nconst modelWeek = $('Read Model Week').all();\nconst status = $('Read System Status').all();\nconst nameOf = (i) => i.json.property_name || i.json.name || '';\nconst detailsOf = (i) => (i && i.json.property_details) || '';\nconst calRow = status.find(i => nameOf(i) === 'Calendar Feed');\nconst adhRow = status.find(i => nameOf(i) === 'Adherence Rolling Summary');\nconst calendarText = detailsOf(calRow);\nconst existing = detailsOf(adhRow);\n\nconst days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];\nconst todayName = days[new Date().getDay()];\n\nlet plannedHours = 0;\nfor (const item of modelWeek) {\n  if ((item.json.property_day || '') !== todayName) continue;\n  if ((item.json.property_energy_cost_tier || '') !== 'High') continue;\n  let tr = item.json.property_time_range || '';\n  tr = tr.replace(/[‒–—―]/g, '-'); // normalize unicode dashes to '-'\n  if (!tr || tr === '-') continue;\n  const parts = tr.split('-');\n  if (parts.length !== 2) continue;\n  const [sh, sm] = parts[0].trim().split(':').map(Number);\n  const [eh, em] = parts[1].trim().split(':').map(Number);\n  if ([sh, sm, eh, em].some(n => Number.isNaN(n))) continue;\n  const h = (eh + em / 60) - (sh + sm / 60);\n  if (h > 0) plannedHours += h;\n}\n\nlet calEventHours = 0;\nfor (const line of String(calendarText).split('\\n')) {\n  const m = line.trim().match(/^(\\d{1,2}):(\\d{2})\\s*[-‒–—―]\\s*(\\d{1,2}):(\\d{2})/);\n  if (!m) continue;\n  const s = parseInt(m[1]) + parseInt(m[2]) / 60;\n  const e = parseInt(m[3]) + parseInt(m[4]) / 60;\n  if (e > s) calEventHours += (e - s);\n}\nconst calFree = Math.max(0, 10 - calEventHours);\n\nconst today = new Date().toISOString().split('T')[0];\nconst newLine = `${today}: planned ${plannedHours.toFixed(1)}h deep-focus, calendar shows ~${calFree.toFixed(1)}h available.`;\n\n// rolling append, capped to last 30 lines to stay under Notion's 2000-char limit\nlet combined = (newLine + '\\n' + existing).split('\\n').filter(l => l.trim()).slice(0, 30).join('\\n');\nreturn [{ json: { newLine, combinedSummary: combined } }];"
      },
