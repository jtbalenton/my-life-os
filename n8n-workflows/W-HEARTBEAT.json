        "jsonBody": "={\n  \"properties\": {\n    \"Active\": { \"checkbox\": {{ $('Find Overdue Jobs').item.json.active }} },\n    \"Details\": { \"rich_text\": [ { \"text\": { \"content\": \"{{ $('Find Overdue Jobs').item.json.details }}\" } } ] },\n    \"Last Updated\": { \"date\": { \"start\": \"{{ $now.toISO() }}\" } }\n  }\n}",
