    {
      "parameters": {
        "jsCode": "const items = $('Read All Heartbeat Rows').all()\n  .filter(i => (i.json.property_item_type || '') === 'Job Heartbeat');\nconst now = Date.now();\nfunction expMs(c) {\n  if (!c) return null;\n  const s = String(c).toLowerCase();\n  if (s.includes('20 min')) return 20*60*1000*1.5;\n  if (s.includes('30 min')) return 30*60*1000*1.5;\n  if (s.includes('daily'))   return 24*3600*1000*1.5;\n  if (s.includes('weekly'))  return 7*24*3600*1000*1.5;\n  if (s.includes('monthly')) return 31*24*3600*1000*1.5;\n  return null;\n}\nconst overdue = [];\nfor (const it of items) {\n  const name = it.json.property_name || it.json.name || 'Unknown';\n  const cadence = it.json.property_expected_cadence;\n  const lu = it.json.property_last_updated && it.json.property_last_updated.start;\n  const ems = expMs(cadence);\n  if (!ems) continue;\n  if (!lu) { overdue.push(`${name} (never run)`); continue; }\n  const elapsed = now - new Date(lu).getTime();\n  if (elapsed > ems) overdue.push(`${name} (${Math.floor(elapsed/3600000)}h ago, expected: ${cadence})`);\n}\nconst active = overdue.length > 0;\nconst details = active ? `Overdue: ${overdue.join('. ')}` : 'All jobs healthy.';\nreturn [{ json: { active, details } }];"
      },
      "id": "301bb5ae-9ada-4c5d-8bc3-a204d0376614",
      "name": "Find Overdue Jobs",
      "type": "n8n-nodes-base.code",
