        "nodeCredentialType": "notionApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"properties\": { \"Active\": { \"checkbox\": {{ $(\"Check Reentry Gap\").item.json.active }} }, \"Details\": { \"rich_text\": [ { \"text\": { \"content\": \"{{ $(\"Check Reentry Gap\").item.json.details }}\" } } ] }, \"Last Updated\": { \"date\": { \"start\": \"{{ $now.toISO() }}\" } } } }",
        "options": {}
