    {
      "id": "f2ac73cf-fdb2-4a4d-a57d-fc79601ee7af",
      "name": "Check Reentry Gap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $('Read Inbox Recent').all();\nlet active = false, details = 'No gap detected.';\nif (!items.length) {\n  details = 'No Inbox items found.';\n} else {\n  let latest = null;\n  for (const it of items) {\n    const d = it.json.property_last_touched && it.json.property_last_touched.start;\n    if (d) { const t = new Date(d); if (!latest || t > latest) latest = t; }\n  }\n  if (!latest) { details = 'No Last Touched date found.'; }\n  else {\n    const diff = (Date.now() - latest.getTime()) / 86400000;\n    if (diff >= 3) { active = true; details = `Gap detected: last activity ${Math.floor(diff)} days ago. Review Inbox and Tickler at next session.`; }\n    else { details = `Last activity ${diff.toFixed(1)} days ago — no gap.`; }\n  }\n}\nreturn [{ json: { active, details } }];"
      }
    },
    {
      "id": "02beb982-ff4f-49cb-b4f3-cc3a37e41b35",
