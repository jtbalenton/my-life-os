    {
      "id": "92cc10ed-2f6e-49af-a89c-c1f0f75b18a0",
      "name": "Collect Changes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const within = (d) => d && (Date.now() - new Date(d).getTime()) <= 6*60000;\nconst lt = (r) => r.json.property_last_touched && r.json.property_last_touched.start;\nconst lu = (r) => r.json.property_last_updated && r.json.property_last_updated.start;\nconst nm = (r) => r.json.property_name || r.json.name || '';\nconst lines = [];\nfor (const r of $('Read Projects').all()) if (within(lt(r))) lines.push('Projects: ' + nm(r));\nfor (const r of $('Read Sprint Goals').all()) if (within(lt(r))) lines.push('Sprint Goals: ' + nm(r));\nfor (const r of $('Read Inbox').all()) if (within(lt(r))) lines.push('Inbox: ' + nm(r));\nconst status = $('Read System Status').all();\nfor (const r of status) {\n  if ((r.json.property_item_type || '') !== 'Dashboard Card') continue;\n  if (r.json.property_active !== true) continue;\n  if (nm(r) === 'Recent Changes') continue;\n  if (within(lu(r))) lines.push('System Status: ' + nm(r));\n}\nconst rc = status.find(r => nm(r) === 'Recent Changes');\nconst prev = (rc && rc.json.property_details ? String(rc.json.property_details).split('\\n').filter(Boolean) : []);\nconst active = lines.length > 0;\nconst combined = active ? [...lines, ...prev].slice(0, 10).join('\\n') : prev.join('\\n');\nreturn [{ json: { active, details: combined } }];"
      }
    },
    {
      "id": "16276d4e-97b5-43f7-9c7d-b990a8cc37b1",
