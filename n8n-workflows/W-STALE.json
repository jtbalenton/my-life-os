    {
      "id": "c7f48525-58d1-4944-81f8-e412106379cc",
      "name": "Find Stale Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const STALE = 21;\nconst now = Date.now();\nconst ltOf = (i) => i.json.property_last_touched && i.json.property_last_touched.start;\nconst nm = (i) => i.json.property_name || i.json.name || 'Unnamed';\nconst scan = (items) => {\n  const out = [];\n  for (const it of items) {\n    if ((it.json.property_state || '') !== 'Active') continue;\n    const raw = ltOf(it);\n    if (!raw) { out.push(`${nm(it)} (no Last Touched date)`); continue; }\n    const days = (now - new Date(raw).getTime()) / 86400000;\n    if (days >= STALE) out.push(`${nm(it)} (${Math.floor(days)} days)`);\n  }\n  return out;\n};\nconst sp = scan($('Read Active Projects').all());\nconst sg = scan($('Read Active Sprint Goals').all());\nconst active = sp.length > 0 || sg.length > 0;\nconst details = `Projects: ${sp.length ? sp.join(', ') + '.' : 'none.'} Sprint Goals: ${sg.length ? sg.join(', ') + '.' : 'none.'}`;\nreturn [{ json: { active, details } }];"
      }
    },
    {
      "id": "95c1629f-f97a-4341-b99d-52427130ce04",
      "name": "Update Staleness Flags",
